{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Zon VM",
            "type": "cppdbg",
            "request": "launch",
            "program": "${env:HOME}/zonetic-vm/zonvm", 
            "args": ["${file}"], // Pasa 'r' y el archivo .zbc actual
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Compilar VM" // Llama a la tarea de arriba antes de empezar
        }
    ]
}
